#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="$APP_DIR/data"
CONFIG_DIR="$APP_DATA_DIR/config"
CONFIG_FILE="$CONFIG_DIR/config.lua"

mkdir -p "$CONFIG_DIR"

if [[ -f "$CONFIG_FILE" ]]; then
  exit 0
fi

cat >"$CONFIG_FILE" <<'EOF'
-- ### General ###
logging = true
debug = false
threads = 10

-- ### Server ###
port = "8080"
binding_ip = "0.0.0.0"
production_use = false
request_timeout = 30
tcp_connection_keep_alive = 30
pool_idle_connection_timeout = 30
rate_limiter = {
 number_of_requests = 20,
 time_limit = 3,
}
https_adaptive_window_size = true
operating_system_tls_certificates = true
number_of_https_connections = 10
client_connection_keep_alive = 120

-- ### Search ###
safe_search = 2

-- ### Website ###
colorscheme = "catppuccin-mocha"
theme = "simple"
animation = "simple-frosted-glow"

-- ### Caching ###
redis_url = "redis://127.0.0.1:8082"
cache_expiry_time = 600
http_cache_expiry_time = 60

-- ### Search Engines ###
upstream_search_engines = {
 DuckDuckGo = true,
 Searx = false,
 Brave = false,
 Startpage = false,
 LibreX = false,
 Mojeek = false,
 Bing = false,
 Qwant = false,
 Wikipedia = true,
 Yahoo = false,
 SepiaSearch = false,
}

proxy = nil
EOF

